<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
    <id>sk.mostka.Respatch</id>
    <metadata_license>CC0-1.0</metadata_license>
    <project_license>MIT</project_license>
    <name>Respatch</name>
    <summary>Monitor Symfony Messenger transports and failed messages</summary>
    <description>
        <p>Note: Respatch is a client application that requires a running Symfony Messenger server with the Respatch monitoring endpoint enabled. See the project homepage for setup instructions.</p>
        <p>
            Respatch is a specialized monitoring tool designed specifically for Symfony Messenger.
            It provides a real-time overview of your message transports, allowing you to track
            successful processing and manage failed messages through a native desktop interface.
        </p>
        <ul>
            <li>Real-time transport status monitoring</li>
            <li>Instant desktop notifications for critical failures</li>
            <li>Management of failed message queues</li>
            <li>Native GNOME experience</li>
        </ul>
    </description>
    <developer id="sk.mostka">
        <name>Jozef Môstka</name>
    </developer>
    <launchable type="desktop-id">sk.mostka.Respatch.desktop</launchable>
