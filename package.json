{
  "name": "respatch",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "scripts": {
    "build:ui": "mkdir -p dist/ui && blueprint-compiler compile src/ui/window.blp > dist/ui/window.ui",
    "build:ts": "esbuild src/main.ts --bundle --format=esm --outfile=dist/main.js --external:gi://*",
    "build": "npm run build:ui && npm run build:ts",
    "start": "npm run build && gjs -m dist/main.js",
    "test": "vitest run"
  },
