{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "types": [
      "@girs/gtk-4.0",
      "@girs/adw-1",
      "@girs/glib-2.0",
      "@girs/gio-2.0"
    ]
  },
  "include": ["src/**/*", "tests/**/*"]
}
